🚀 QUICK START COMMANDS
bash
# 1. Install everything
python install_module0.py --project-dir ~/mydrive/a-lems

# 2. Log out and back in (for group changes)

# 3. Activate environment
cd ~/mydrive/a-lems
source venv/bin/activate

# 4. Verify hardware
python scripts/verify_hardware.py

# 5. Set up API keys
cp .env.example .env
nano .env  # Add your GROQ_API_KEY

# 6. Test LLM connectivity
python core/execution/tests/test_llm_setup.py

# 7. Quick test
python scripts/test_harness.py --repetitions 3 --task "What is 2+2?"

# 8. Run full experiment
python scripts/run_real_experiment.py --repetitions 30 --tasks all --output results/study1.json
