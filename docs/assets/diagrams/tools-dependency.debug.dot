digraph {
  rankdir=TB;
  compound=True;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;
  "tool.llm" [label="llm_context.py", shape="box", color="lightgray"];
  "tool.sphinx" [label="sphinx_docs.py", shape="box", color="lightgray"];
  "tool.mkdocs" [label="mkdocs_docs.py", shape="box", color="lightgray"];
  "tool.quality" [label="quality_check.py", shape="box", color="lightgray"];
  "tool.refactor" [label="refactor_advisor.py", shape="box", color="lightgray"];
  "tool.team" [label="team_dashboard.py", shape="box", color="lightgray"];
  "tool.web" [label="web_controller.py", shape="box", color="lightgray"];
  "tool.verify" [label="verify_requirements.py", shape="box", color="lightgray"];
  "tool.column" [label="column_flow.py", shape="box", color="lightgray"];
  "tool.diagram" [label="generate_diagrams.py", shape="box", color="lightgray"];
  "tool.issue" [label="issue_tracer.py", shape="box", color="lightgray"];
  "tool.path" [label="path_loader.py", shape="box", color="lightblue"];
  "tool.path" -> "tool.llm" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.sphinx" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.mkdocs" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.quality" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.refactor" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.team" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.web" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.verify" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.column" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.diagram" [style=solid, color=blue, arrowhead=normal];
  "tool.path" -> "tool.issue" [style=solid, color=blue, arrowhead=normal];
  "tool.web" -> "tool.llm" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.sphinx" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.mkdocs" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.quality" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.refactor" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.team" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.verify" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.column" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.diagram" [style=dashed, color=black, arrowhead=normal, label="calls"];
  "tool.web" -> "tool.issue" [style=dashed, color=black, arrowhead=normal, label="calls"];
}