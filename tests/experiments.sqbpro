SELECT 
    'runs' as table_name,
    COUNT(*) as total_rows,
    SUM(CASE WHEN run_id IS NULL THEN 1 ELSE 0 END) as null_run_id,
    SUM(CASE WHEN exp_id IS NULL THEN 1 ELSE 0 END) as null_exp_id,
    SUM(CASE WHEN run_number IS NULL THEN 1 ELSE 0 END) as null_run_number,
    SUM(CASE WHEN workflow_type IS NULL THEN 1 ELSE 0 END) as null_workflow,
    SUM(CASE WHEN start_time_ns IS NULL THEN 1 ELSE 0 END) as null_start_time,
    SUM(CASE WHEN end_time_ns IS NULL THEN 1 ELSE 0 END) as null_end_time,
    SUM(CASE WHEN duration_ns IS NULL THEN 1 ELSE 0 END) as null_duration,
    SUM(CASE WHEN total_energy_uj IS NULL THEN 1 ELSE 0 END) as null_energy,
    SUM(CASE WHEN instructions IS NULL THEN 1 ELSE 0 END) as null_instructions,
    SUM(CASE WHEN ipc IS NULL THEN 1 ELSE 0 END) as null_ipc,
    SUM(CASE WHEN package_temp_celsius IS NULL THEN 1 ELSE 0 END) as null_temp
FROM runs;</sql><current_tab id="0"/></tab_sql></sqlb_project>
