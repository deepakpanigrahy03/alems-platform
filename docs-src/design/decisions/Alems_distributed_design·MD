## 5. UUID generation strategy

```python
# alems/shared/uuid_gen.py

import uuid

# Stable namespace for A-LEMS (generated once, fixed forever)
_ALEMS_NS = uuid.UUID("6ba7b810-9dad-11d1-80b4-00c04fd430c8")  # UUID5 namespace

def run_uuid(hw_id: int, run_id: int) -> str:
    """
    Deterministic UUID for existing rows.
    Given the same hw_id + run_id always produces the same UUID.
    Used for backfilling existing 1554 runs.
    """
    return str(uuid.uuid5(_ALEMS_NS, f"run:{hw_id}:{run_id}"))

def exp_uuid(hw_id: int, exp_id: int) -> str:
    """Deterministic UUID for existing experiments."""
    return str(uuid.uuid5(_ALEMS_NS, f"exp:{hw_id}:{exp_id}"))

def new_run_uuid() -> str:
    """Random UUID for new runs (created after migration)."""
    return str(uuid.uuid4())

def new_exp_uuid() -> str:
    """Random UUID for new experiments."""
    return str(uuid.uuid4())
```

**Backfill logic for existing 1554 runs:**
```python
# alems/agent/backfill.py
# Run ONCE on first agent startup after migration

def backfill_global_ids(db_path: str, hw_id: int):
    """
    Fills global_run_id and global_exp_id for existing rows
    that predate the distributed migration.
    Idempotent — safe to run multiple times.
    """
    import sqlite3
    from alems.shared.uuid_gen import run_uuid, exp_uuid
    
    con = sqlite3.connect(db_path)
    
    # Backfill experiments
    rows = con.execute(
        "SELECT exp_id FROM experiments WHERE global_exp_id IS NULL"
    ).fetchall()
    for (exp_id,) in rows:
        uid = exp_uuid(hw_id, exp_id)
        con.execute(
            "UPDATE experiments SET global_exp_id=? WHERE exp_id=?",
            (uid, exp_id)
        )
    
    # Backfill runs
    rows = con.execute(
        "SELECT run_id FROM runs WHERE global_run_id IS NULL"
    ).fetchall()
    for (run_id,) in rows:
        uid = run_uuid(hw_id, run_id)
        con.execute(
            "UPDATE runs SET global_run_id=? WHERE run_id=?",
            (uid, run_id)
        )
    
    # Backfill child tables from runs
    for tbl in ["energy_samples","cpu_samples","thermal_samples",
                "interrupt_samples","orchestration_events","llm_interactions"]:
        con.execute(f"""
            UPDATE {tbl} SET global_run_id = (
                SELECT global_run_id FROM runs WHERE runs.run_id = {tbl}.run_id
            )
            WHERE global_run_id IS NULL
        """)
    
    con.commit()
    con.close()
    print(f"Backfill complete: {len(rows)} runs, {len(rows)} experiments updated")
```

