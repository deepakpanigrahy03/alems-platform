## 4. SQLAlchemy dialect layer (query compatibility)

This is the key to "same query runs on SQLite and PostgreSQL":

```python
# alems/shared/db_layer.py

from sqlalchemy import create_engine, text
from sqlalchemy.orm import Session
from contextlib import contextmanager
import os

def get_engine(db_url: str = None):
    """
    Returns a SQLAlchemy engine for either SQLite or PostgreSQL.
    Detected from URL scheme or ALEMS_DB_URL env var.
    """
    url = db_url or os.environ.get("ALEMS_DB_URL", f"sqlite:///{_default_sqlite_path()}")
    
    if url.startswith("sqlite"):
        return create_engine(url, connect_args={"check_same_thread": False})
    else:
        # PostgreSQL
        return create_engine(url, pool_pre_ping=True, pool_size=10)

@contextmanager  
def get_session(engine) -> Session:
    with Session(engine) as session:
        yield session

# ── Query helpers that paper over dialect differences ──────────────────────

def now_expr(engine) -> str:
    """Returns dialect-correct NOW() expression."""
    if _is_sqlite(engine):
        return "datetime('now')"
    return "NOW()"

def upsert_hardware(session, hardware_hash: str, hw_data: dict) -> int:
    """
    Upsert hardware_config by hardware_hash.
    Returns hw_id. Works on both SQLite and PostgreSQL.
    """
    engine = session.get_bind()
    if _is_sqlite(engine):
        session.execute(text("""
            INSERT INTO hardware_config (hardware_hash, hostname, cpu_model, ...)
            VALUES (:hardware_hash, :hostname, :cpu_model, ...)
            ON CONFLICT (hardware_hash) DO UPDATE SET
                last_seen = datetime('now')
        """), {**hw_data, "hardware_hash": hardware_hash})
    else:
        session.execute(text("""
            INSERT INTO hardware_config (hardware_hash, hostname, cpu_model, ...)
            VALUES (:hardware_hash, :hostname, :cpu_model, ...)
            ON CONFLICT (hardware_hash) DO UPDATE SET
                last_seen = NOW(),
                agent_status = EXCLUDED.agent_status
        """), {**hw_data, "hardware_hash": hardware_hash})
    
    row = session.execute(text(
        "SELECT hw_id FROM hardware_config WHERE hardware_hash = :h"
    ), {"h": hardware_hash}).fetchone()
    return row.hw_id

def get_unsynced_runs(session, limit: int = 100) -> list:
    """Fetch runs with sync_status=0. Same query both dialects."""
    return session.execute(text("""
        SELECT r.run_id, r.global_run_id, r.exp_id, r.global_exp_id, r.hw_id
        FROM runs r
        WHERE r.sync_status = 0
        ORDER BY r.run_id ASC
        LIMIT :limit
    """), {"limit": limit}).fetchall()

def mark_runs_synced(session, global_run_ids: list[str]):
    """Mark runs as synced. Same query both dialects."""
    session.execute(text("""
        UPDATE runs SET sync_status = 1
        WHERE global_run_id IN :ids
    """), {"ids": tuple(global_run_ids)})

def _is_sqlite(engine) -> bool:
    return engine.dialect.name == "sqlite"

def _default_sqlite_path() -> str:
    from pathlib import Path
    return str(Path.home() / "mydrive" / "a-lems" / "data" / "experiments.db")
```

