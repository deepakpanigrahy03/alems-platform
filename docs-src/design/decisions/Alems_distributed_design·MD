## 6. Agent design

```python
# alems/agent/agent.py  — simplified pseudocode

import time, subprocess, threading
from alems.agent.heartbeat import send_heartbeat
from alems.agent.job_executor import execute_job
from alems.agent.sync_client import sync_unsynced_runs
from alems.agent.mode_manager import get_mode, get_server_url

HEARTBEAT_INTERVAL = 30   # seconds
POLL_INTERVAL      = 10   # seconds
SYNC_INTERVAL      = 60   # seconds (also triggered after each run)

_active_run = threading.Event()  # SET when a run is in progress

def run_agent():
    print(f"A-LEMS Agent starting — mode={get_mode()}")
    
    # Backfill UUIDs on first run
    from alems.agent.backfill import backfill_global_ids
    backfill_global_ids(...)
    
    threads = [
        threading.Thread(target=_heartbeat_loop, daemon=True),
        threading.Thread(target=_poll_loop,      daemon=True),
        threading.Thread(target=_sync_loop,      daemon=True),
    ]
    for t in threads: t.start()
    for t in threads: t.join()

def _heartbeat_loop():
    while True:
        if get_mode() == "connected":
            send_heartbeat(
                busy=_active_run.is_set(),
                server_url=get_server_url()
            )
        time.sleep(HEARTBEAT_INTERVAL)

def _poll_loop():
    while True:
        if get_mode() == "connected" and not _active_run.is_set():
            job = fetch_job(server_url=get_server_url())
            if job:
                _active_run.set()
                try:
                    execute_job(job)   # calls test_harness subprocess
                    sync_unsynced_runs(immediately=True)
                finally:
                    _active_run.clear()
        time.sleep(POLL_INTERVAL)

def _sync_loop():
    while True:
        time.sleep(SYNC_INTERVAL)
        if get_mode() == "connected":
            sync_unsynced_runs()
```

