```python
# alems/server/job_dispatcher.py

def get_next_job(hw_id: int, session) -> dict | None:
    """
    Returns next job for hw_id, or None if machine is busy or queue empty.
    Double-checked: server state + agent self-reports busy via heartbeat.
    """
    # Check if machine has an active job in server state
    active = session.execute(text("""
        SELECT job_id FROM job_queue
        WHERE dispatched_to_hw_id = :hw_id
          AND status = 'running'
        LIMIT 1
    """), {"hw_id": hw_id}).fetchone()
    
    if active:
        return None  # machine is busy — do not dispatch
    
    # Find next available job (respecting target_hw_id preference)
    job = session.execute(text("""
        SELECT * FROM job_queue
        WHERE status = 'pending'
          AND (target_hw_id IS NULL OR target_hw_id = :hw_id)
        ORDER BY priority DESC, created_at ASC
        LIMIT 1
    """), {"hw_id": hw_id}).fetchone()
    
    if not job:
        return None
    
    # Atomically mark as dispatched
    session.execute(text("""
        UPDATE job_queue
        SET status='dispatched', dispatched_to_hw_id=:hw_id, dispatched_at=NOW()
        WHERE job_id=:job_id AND status='pending'
    """), {"hw_id": hw_id, "job_id": job.job_id})
    
    return job
```

**What happens when agent goes offline mid-run:**
```python
# Runs every 2 minutes on server — checks for stale dispatched jobs
def reap_stale_jobs(session):
    machines = session.execute(text("""
        SELECT hw_id, last_seen, agent_status FROM hardware_config
        WHERE agent_status = 'busy'
          AND last_seen < NOW() - INTERVAL '3 minutes'
    """)).fetchall()
    
    for m in machines:
        job = session.execute(text("""
            SELECT job_id, on_disconnect FROM job_queue
            WHERE dispatched_to_hw_id = :hw_id AND status = 'running'
        """), {"hw_id": m.hw_id}).fetchone()
        
        if not job: continue
        
        if job.on_disconnect == "fail":
            session.execute(text("""
                UPDATE job_queue SET status='failed', error_message='agent_offline'
                WHERE job_id=:id
            """), {"id": job.job_id})
        
        elif job.on_disconnect == "requeue":
            session.execute(text("""
                UPDATE job_queue
                SET status='pending', dispatched_to_hw_id=NULL, retry_count=retry_count+1
                WHERE job_id=:id AND retry_count < max_retries
            """), {"id": job.job_id})
        
        elif job.on_disconnect == "wait":
            pass  # leave as 'running', agent will resume on reconnect
```

